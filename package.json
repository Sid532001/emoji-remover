{
  "name": "emoji-remover",
  "displayName": "Emoji Remover",
  "description": "Remove AI-generated emojis from code, markdown, and documentation — file by file or across your entire project.",
  "version": "0.1.0",
  "publisher": "prayogshala",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Formatters"
  ],
  "keywords": [
    "emoji",
    "remove",
    "clean",
    "documentation",
    "ai",
    "code"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "emojiRemover.removeFromCurrentFile",
        "title": "Remove Emojis from Current File",
        "category": "Emoji Remover"
      },
      {
        "command": "emojiRemover.removeFromFile",
        "title": "Remove Emojis from This File",
        "category": "Emoji Remover"
      },
      {
        "command": "emojiRemover.removeFromFolder",
        "title": "Remove Emojis from This Folder",
        "category": "Emoji Remover"
      },
      {
        "command": "emojiRemover.removeFromProject",
        "title": "Remove Emojis from Entire Project",
        "category": "Emoji Remover"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "emojiRemover.removeFromFile",
          "when": "resourceScheme == 'file' && !explorerResourceIsFolder",
          "group": "emojiRemover@1"
        },
        {
          "command": "emojiRemover.removeFromFolder",
          "when": "explorerResourceIsFolder",
          "group": "emojiRemover@1"
        }
      ],
      "editor/context": [
        {
          "command": "emojiRemover.removeFromCurrentFile",
          "group": "emojiRemover@1"
        }
      ],
      "commandPalette": [
        {
          "command": "emojiRemover.removeFromCurrentFile",
          "when": "editorIsOpen"
        },
        {
          "command": "emojiRemover.removeFromFile",
          "when": "false"
        },
        {
          "command": "emojiRemover.removeFromFolder",
          "when": "false"
        },
        {
          "command": "emojiRemover.removeFromProject"
        }
      ]
    },
    "configuration": {
      "title": "Emoji Remover",
      "properties": {
        "emojiRemover.includedExtensions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            ".txt", ".md", ".mdx", ".rst", ".adoc", ".asciidoc",
            ".js", ".jsx", ".ts", ".tsx", ".mjs", ".cjs", ".vue", ".svelte",
            ".py", ".pyw", ".rb", ".go", ".rs", ".java", ".kt", ".kts",
            ".c", ".cpp", ".h", ".hpp", ".cc", ".cxx", ".cs", ".swift", ".scala",
            ".php", ".pl", ".sh", ".bash", ".zsh", ".fish", ".ps1", ".psm1",
            ".html", ".htm", ".xml", ".xhtml", ".svg",
            ".css", ".scss", ".sass", ".less", ".styl",
            ".json", ".jsonc", ".json5", ".yaml", ".yml", ".toml", ".ini", ".cfg", ".conf", ".env",
            ".sql", ".graphql", ".gql", ".proto",
            ".tf", ".tfvars", ".hcl",
            ".r", ".jl", ".lua", ".dart", ".ex", ".exs", ".erl",
            ".clj", ".cljs", ".hs", ".elm", ".ml"
          ],
          "markdownDescription": "File extensions to include when scanning for emojis. Each entry must start with `.` (e.g. `.md`, `.ts`)."
        },
        "emojiRemover.excludedDirectories": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "node_modules", ".git", ".svn", ".hg", ".bzr",
            "dist", "build", "out", "output", ".next", ".nuxt", ".output",
            "__pycache__", ".venv", "venv", "env",
            ".idea", "vendor", "coverage", ".nyc_output", ".cache",
            "target", "bin", "obj"
          ],
          "markdownDescription": "Directory names to skip when scanning a folder or project."
        },
        "emojiRemover.confirmBeforeProjectScan": {
          "type": "boolean",
          "default": true,
          "description": "Show a confirmation dialog before removing emojis from the entire project."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.3.0"
  }
}
